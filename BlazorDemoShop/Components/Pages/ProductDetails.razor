@page "/products/{Id:int}"
@inject ApiProductsClientService ApiProductsClient
@using System.Globalization

<PageTitle>Товар</PageTitle>

<section class="page-shell product-details-shell">
    @if (_isLoading)
    {
        <p class="loading-pill">Загружаем карточку товара...</p>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @_errorMessage
        </div>
    }
    else if (_product is null)
    {
        <div class="alert alert-warning" role="alert">
            Товар не найден.
        </div>
    }
    else
    {
        <h1>@_product.Name</h1>

        <div class="card product-details-card">
            <div class="product-details-image-wrap">
                <button type="button"
                        class="product-carousel-nav product-carousel-prev"
                        disabled="@(_productImages.Count <= 1)"
                        @onclick="ShowPreviousImage">
                    ‹
                </button>

                <img class="product-details-image"
                     src="@CurrentImageUrl"
                     alt="@_product.Name"
                     loading="lazy" />

                <button type="button"
                        class="product-carousel-nav product-carousel-next"
                        disabled="@(_productImages.Count <= 1)"
                        @onclick="ShowNextImage">
                    ›
                </button>

                <div class="product-carousel-counter">
                    @(_activeImageIndex + 1) / @_productImages.Count
                </div>
            </div>

            <div class="card-body">
                <p class="product-card-price mb-2">@FormatPrice(_product.Price)</p>
                <p class="mb-2">@GetDescription(_product.Description)</p>
                <p class="text-muted mb-4">Купили: @_product.TimeBought раз</p>
                <NavLink class="btn btn-primary" href="/products">Назад к каталогу</NavLink>
            </div>
        </div>

        <AuthorizeView Roles="user">
            <Authorized>
                <button class="buy-button">
                    Add to cart
                </button>
            </Authorized>
        </AuthorizeView>

        <AuthorizeView Roles="admin">
            <Authorized>
                <NavLink class="btn btn-outline-secondary mt-3" href="@($"/products/{_product.Id}/edit")">
                    Edit product
                </NavLink>
            </Authorized>
        </AuthorizeView>
    }
</section>

@code {
    private const string PlaceholderImage = "https://placehold.co/960x640/efe4d4/5f4638?text=No+Image";
    private static readonly CultureInfo PriceCulture = CultureInfo.GetCultureInfo("ru-RU");

    [Parameter]
    public int Id { get; set; }

    private bool _isLoading = true;
    private int _activeImageIndex;
    private string? _errorMessage;
    private ProductDTO? _product;
    private List<string> _productImages = new();

    private string CurrentImageUrl
        => _productImages.Count == 0
            ? PlaceholderImage
            : _productImages[_activeImageIndex];

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _product = null;
        _productImages = new List<string>();
        _activeImageIndex = 0;

        try
        {
            _product = await ApiProductsClient.GetProductByIdAsync(Id);

            if (_product is not null)
            {
                _productImages = NormalizeImageUrls(_product.Images);
                if (_productImages.Count == 0)
                {
                    _productImages.Add(GetImageUrl(_product.MainImage));
                }
            }
        }
        catch
        {
            _errorMessage = "Не удалось загрузить товар.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ShowPreviousImage()
    {
        if (_productImages.Count <= 1)
        {
            return;
        }

        _activeImageIndex = (_activeImageIndex - 1 + _productImages.Count) % _productImages.Count;
    }

    private void ShowNextImage()
    {
        if (_productImages.Count <= 1)
        {
            return;
        }

        _activeImageIndex = (_activeImageIndex + 1) % _productImages.Count;
    }

    private static List<string> NormalizeImageUrls(IEnumerable<string>? imageUrls)
    {
        return (imageUrls ?? Array.Empty<string>())
            .Select(GetImageUrl)
            .Distinct()
            .ToList();
    }

    private static string GetImageUrl(string? imageUrl)
    {
        return string.IsNullOrWhiteSpace(imageUrl) ? PlaceholderImage : imageUrl;
    }

    private static string GetDescription(string? description)
    {
        return string.IsNullOrWhiteSpace(description)
            ? "Описание товара пока не добавлено."
            : description;
    }

    private static string FormatPrice(decimal price)
    {
        return string.Format(PriceCulture, "{0:N2} ₽", price);
    }
}

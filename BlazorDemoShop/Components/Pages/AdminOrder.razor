@page "/admin/orders/{Id:int}"
@attribute [Authorize(Roles = "admin")]
@inject ApiProductsClientService ApiProductsClient
@inject AuthenticationStateProvider AuthenticationStateProvider
@using System.Globalization

<PageTitle>Заказ администратора</PageTitle>

<section class="page-shell admin-order-shell">
    @if (_isLoading)
    {
        <p class="loading-pill">Загружаем детали заказа...</p>
    }
    else if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @_errorMessage
        </div>
    }
    else if (_order is null)
    {
        <div class="alert alert-warning" role="alert">
            Заказ не найден.
        </div>
    }
    else
    {
        <h1 class="mb-3">Заказ №@_order.Id</h1>

        <div class="@OrderStatusUiHelper.GetBadgeCssClass(_order.StatusTitle)">
            @OrderStatusUiHelper.GetDisplayTitle(_order.StatusTitle)
        </div>

        <div class="card admin-order-meta-card mt-3">
            <div class="card-body">
                <div class="admin-order-row">
                    <span>Id заказа</span>
                    <strong>@_order.Id</strong>
                </div>

                <div class="admin-order-row">
                    <span>Пользователь</span>
                    <strong>@GetUserTitle(_order)</strong>
                </div>

                <div class="admin-order-row">
                    <span>Стоимость</span>
                    <strong>@FormatPrice(_order.FullCost)</strong>
                </div>

                <div class="admin-order-row">
                    <span>Создан</span>
                    <strong>@FormatDateTime(_order.CreateDate)</strong>
                </div>

                <div class="admin-order-row">
                    <span>Получен</span>
                    <strong>@FormatNullableDateTime(_order.RecieveDate)</strong>
                </div>

                <div class="admin-order-row admin-order-row-last">
                    <span>Статус</span>
                    <span class="@OrderStatusUiHelper.GetBadgeCssClass(_order.StatusTitle)">
                        @OrderStatusUiHelper.GetDisplayTitle(_order.StatusTitle)
                    </span>
                </div>
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-body">
                <h2 class="h5 mb-3">Изменение статуса</h2>

                @if (!string.IsNullOrWhiteSpace(_statusUpdateError))
                {
                    <div class="alert alert-danger" role="alert">
                        @_statusUpdateError
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(_statusUpdateSuccess))
                {
                    <div class="alert alert-success" role="alert">
                        @_statusUpdateSuccess
                    </div>
                }

                @if (!CanEditOrderStatus)
                {
                    <div class="alert alert-warning" role="alert">
                        Статус завершенного или отмененного заказа редактировать нельзя.
                    </div>
                }

                @if (_availableStatuses.Count == 0)
                {
                    <div class="alert alert-warning mb-0" role="alert">
                        Нет доступных статусов заказа.
                    </div>
                }
                else
                {
                    <div class="admin-order-status-editor">
                        <select class="form-select"
                                value="@_selectedStatusId"
                                @onchange="OnStatusChanged"
                                disabled="@(_isUpdatingStatus || !CanEditOrderStatus)">
                            @foreach (var status in _availableStatuses)
                            {
                                <option value="@status.Id">@status.Title</option>
                            }
                        </select>

                        <button type="button"
                                class="btn btn-success"
                                disabled="@(_isUpdatingStatus || !CanEditOrderStatus || _selectedStatusId <= 0 || _selectedStatusId == _order.StatusId)"
                                @onclick="UpdateStatusAsync">
                            @(_isUpdatingStatus ? "Сохраняем..." : "Сохранить статус")
                        </button>
                    </div>
                }
            </div>
        </div>

        <div class="card mt-3">
            <div class="card-body">
                <h2 class="h5 mb-3">Товары в заказе</h2>

                @if (_order.OrderItems.Count == 0)
                {
                    <div class="alert alert-warning mb-0" role="alert">
                        В заказе нет позиций.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0 order-items-table">
                            <thead>
                                <tr>
                                    <th scope="col">Товар Id</th>
                                    <th scope="col">Название</th>
                                    <th scope="col" class="text-end">Цена</th>
                                    <th scope="col" class="text-end">Кол-во</th>
                                    <th scope="col" class="text-end">Сумма</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in _order.OrderItems)
                                {
                                    <tr>
                                        <td>
                                            <NavLink href="@($"/products/{item.ProductId}")">@item.ProductId</NavLink>
                                        </td>
                                        <td>
                                            <NavLink href="@($"/products/{item.ProductId}")">@GetProductTitle(item)</NavLink>
                                        </td>
                                        <td class="text-end">@FormatPrice(item.ProductPrice ?? 0m)</td>
                                        <td class="text-end">@item.Count</td>
                                        <td class="text-end">@FormatPrice(item.TotalPrice)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <NavLink class="btn btn-primary mt-3" href="/admin/orders">К списку заказов</NavLink>
    }
</section>

@code {
    private static readonly CultureInfo PriceCulture = CultureInfo.GetCultureInfo("ru-RU");
    private static readonly CultureInfo DateTimeCulture = CultureInfo.GetCultureInfo("ru-RU");

    [Parameter]
    public int Id { get; set; }

    private bool _isLoading = true;
    private bool _isUpdatingStatus;
    private int _selectedStatusId;
    private string? _errorMessage;
    private string? _statusUpdateError;
    private string? _statusUpdateSuccess;
    private OrderDTO? _order;
    private List<OrderStatusDTO> _availableStatuses = new();

    private bool CanEditOrderStatus => _order is not null && OrderStatusUiHelper.CanEditByAdmin(_order.StatusTitle);

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _statusUpdateError = null;
        _statusUpdateSuccess = null;
        _order = null;
        _availableStatuses = new List<OrderStatusDTO>();
        _selectedStatusId = 0;

        try
        {
            var accessToken = await GetAccessTokenAsync();
            if (string.IsNullOrWhiteSpace(accessToken))
            {
                _errorMessage = "Не удалось определить токен авторизации.";
                return;
            }

            _order = await ApiProductsClient.GetOrderByIdAsync(Id, accessToken);
            _availableStatuses = await ApiProductsClient.GetOrderStatusesAsync(accessToken);

            if (_order is not null)
            {
                _selectedStatusId = _order.StatusId;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task UpdateStatusAsync()
    {
        if (_order is null || !CanEditOrderStatus || _selectedStatusId <= 0 || _isUpdatingStatus)
        {
            return;
        }

        _isUpdatingStatus = true;
        _statusUpdateError = null;
        _statusUpdateSuccess = null;

        try
        {
            var accessToken = await GetAccessTokenAsync();
            if (string.IsNullOrWhiteSpace(accessToken))
            {
                _statusUpdateError = "Не удалось определить токен авторизации.";
                return;
            }

            var updatedOrder = await ApiProductsClient.UpdateOrderStatusAsync(_order.Id, _selectedStatusId, accessToken);
            _order = updatedOrder;
            _selectedStatusId = updatedOrder.StatusId;
            _statusUpdateSuccess = "Статус заказа обновлен.";
        }
        catch (Exception ex)
        {
            _statusUpdateError = ex.Message;
        }
        finally
        {
            _isUpdatingStatus = false;
        }
    }

    private void OnStatusChanged(ChangeEventArgs args)
    {
        if (args.Value is null)
        {
            return;
        }

        if (int.TryParse(args.Value.ToString(), out var statusId))
        {
            _selectedStatusId = statusId;
        }
    }

    private async Task<string?> GetAccessTokenAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        return authState.User.FindFirst(AuthClaimTypes.AccessToken)?.Value;
    }

    private static string FormatPrice(decimal price)
    {
        return string.Format(PriceCulture, "{0:N2} ₽", price);
    }

    private static string FormatDateTime(DateTime dateTime)
    {
        return dateTime.ToString("dd.MM.yyyy HH:mm", DateTimeCulture);
    }

    private static string FormatNullableDateTime(DateTime? dateTime)
    {
        return dateTime.HasValue
            ? FormatDateTime(dateTime.Value)
            : "Не указано";
    }

    private static string GetProductTitle(OrderItemDTO item)
    {
        return string.IsNullOrWhiteSpace(item.ProductName)
            ? $"Товар #{item.ProductId}"
            : item.ProductName;
    }

    private static string GetUserTitle(OrderDTO order)
    {
        return string.IsNullOrWhiteSpace(order.UserName)
            ? $"Пользователь #{order.UserId}"
            : $"{order.UserName} (#{order.UserId})";
    }
}

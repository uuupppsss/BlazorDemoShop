@page "/login"
@inject ApiAuthClient ApiAuthClient
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JsRuntime
@inject NavigationManager NavigationManager

<PageTitle>Авторизация</PageTitle>

<h1>Авторизация</h1>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger" role="alert">
        @_errorMessage
    </div>
}

<EditForm Model="_model" OnValidSubmit="HandleSignInAsync" FormName="login-form">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <InputText id="email" class="form-control" @bind-Value="_model.Email" />
    </div>

    <div class="mb-3">
        <label for="password" class="form-label">Пароль</label>
        <InputText id="password" class="form-control" type="password" @bind-Value="_model.Password" />
    </div>

    <button type="submit" class="btn btn-primary" disabled="@_isBusy">
        @(_isBusy ? "Выполняется вход..." : "Войти")
    </button>
</EditForm>

<p class="mt-3">
    Нет аккаунта? <a href="/register">Зарегистрироваться</a>
</p>

@code {
    private readonly LoginInputModel _model = new();
    private bool _isBusy;
    private string? _errorMessage;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        if (authState.User.Identity?.IsAuthenticated == true)
        {
            NavigationManager.NavigateTo(GetSafeReturnUrl(), forceLoad: true);
        }
    }

    private async Task HandleSignInAsync()
    {
        _isBusy = true;
        _errorMessage = null;

        try
        {
            var response = await ApiAuthClient.SignInAsync(new LoginDTO
            {
                Email = _model.Email.Trim(),
                Password = _model.Password
            });

            if (!response.Success)
            {
                _errorMessage = response.Message ?? "Не удалось выполнить вход.";
                return;
            }

            await JsRuntime.InvokeVoidAsync("authSession.signIn", new SessionSignInRequest
            {
                UserId = response.UserId,
                UserName = response.UserName ?? _model.Email,
                Email = response.Email,
                Token = response.Token,
                TokenExpiration = response.TokenExpiration
            });

            NavigationManager.NavigateTo(GetSafeReturnUrl(), forceLoad: true);
        }
        catch (Exception)
        {
            _errorMessage = "Ошибка при подключении к Api";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private string GetSafeReturnUrl()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
        {
            return "/profile";
        }

        if (!ReturnUrl.StartsWith('/') || ReturnUrl.StartsWith("//"))
        {
            return "/profile";
        }

        return ReturnUrl;
    }

    private class LoginInputModel
    {
        [Required(ErrorMessage = "Укажите email")]
        [EmailAddress(ErrorMessage = "Некорректный email")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Укажите пароль")]
        public string Password { get; set; } = string.Empty;
    }
}
